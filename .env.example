# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Apenas no servidor (nunca expor no cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# WhatsApp Business API (Meta Cloud API)
# Token customizado que você define para verificar o webhook
WHATSAPP_VERIFY_TOKEN=meu_token_secreto_123

# App Secret do seu app Meta Developer (para validar HMAC dos webhooks)
WHATSAPP_APP_SECRET=abcdef1234567890abcdef1234567890

# Token de acesso permanente gerado no Meta Business Manager
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do número de telefone no Meta (ex: 123456789012345)
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# URL base do seu deploy (sem barra final)
NEXTAUTH_URL=http://localhost:3000
